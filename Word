#include <iostream>
#include<string>
using namespace std;
 
int main(){
 
    string s; cin>>s;
    int counter1=0,counter2=0;
 
    for(int i=0;i<s.size();i++){
 
        if(s[i]>=97 && s[i]<=122){
         counter1++;
        }
 
         else if(s[i]>=65 && s[i]<=90){
         counter2++;
        }
    }
         for(int i=0;i<s.size();i++){
 
            if(counter1>=counter2){
            s[i]=tolower(s[i]);
            }
 
            else {
            s[i]=toupper(s[i]);
            }
         }
 
     cout<<s;
}
 
