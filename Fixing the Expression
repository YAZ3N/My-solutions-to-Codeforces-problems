#include<bits/stdc++.h>
using namespace std;
 int main(){
 
   int t;cin>>t;
   int n1,n2;
   char op;
 
   while(t--){
    cin>>n1>>op>>n2;
 
    if(op=='>'){
      if(n1>n2){
        cout<<n1<<op<<n2<<endl;
      }
      else if (n1<n2){
        cout<<n1<<"<"<<n2<<endl;
      }
      else{
        cout<<n1<<"="<<n2<<endl;
      }
    }
   else if(op=='<'){
         if(n1<n2){
        cout<<n1<<op<<n2<<endl;
      }
      else if (n1>n2){
        cout<<n1<<">"<<n2<<endl;
      }
      else{
        cout<<n1<<"="<<n2<<endl;
      }
    }
    else if(op=='='){
        if(n1==n2){
        cout<<n1<<op<<n2<<endl;
      }
      else{
         if(n1>n2){
        cout<<n1<<'>'<<n2<<endl;
      }
      else{
        cout<<n1<<'<'<<n2<<endl;
      }
 
      }
 
    }
   }
 }
