#include<bits/stdc++.h>
using namespace std;
 int main(){
 
 int t;cin>>t;
 long long * arr=new long long[t];
 int m=0,counter=0;
 
 for(int i=0;i<t;i++){
    cin>>arr[i];
    counter=0;
    while(arr[i]%2==0){
     counter++;
     arr[i]/=2;
    }
    if(counter>m){
        m=counter;
    }
 }
 
  cout<<m;
 
 
 }
