#include <iostream>
 
using namespace std;
 
int main(){
 
    int n;
    cin>>n;
    int x;
    int counter1,counter2,res=0;
    while(n--){
    counter1=0,counter2=0;
    for(int i=0;i<3;i++){
 
      cin>>x;
      if(x==1){
        counter1++;
      }
      else if(x==0){
        counter2++;
      }
 
    }
    if(counter1>counter2)
    res++;
 
}
cout<<res;
}
 
