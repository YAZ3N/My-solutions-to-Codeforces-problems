#include <iostream>
using namespace std;
int main() {
    int n; cin >> n;
    int index=0;
    int* array = new int[n];
    int min;
    for (int i = 0; i <n; i++) {
        cin >>array[i];
    }
    min = array[0];
    for (int i = 0; i < n; i++) {
   
        if (array[i] < min) {
            min = array[i];
            index = i;
        }
    }
  cout << min << " " << index+1;
}
