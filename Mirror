#include <iostream>
 
using namespace std;
 
int main()
{
   int n;
   cin>>n;
   int x,res1,res2,sum1,sum2;
 
   while(n--){
 
    sum1=0;
    sum2=0;
    res1=0;
 
 
    cin>>x;
 
   res1=x%1000;
   x/=1000;
 
   res2=x%1000;
   x/=1000;
 
   for(int i=0;i<3;i++){
    sum1+=res1%10;
    res1/=10;
   }
 
   for(int i=0;i<3;i++){
    sum2+=res2%10;
    res2/=10;
   }
    if(sum1==sum2){
        cout<<"yes"<<endl;
    }
    else{
        cout<<"no"<<endl;
    }
 
}
}
 
